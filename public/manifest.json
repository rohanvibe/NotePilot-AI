{
    "id": "ai-notes-organizer-pwa-final-v5",
    "name": "AI Notes Organizer",
    "short_name": "AI Notes",
    "description": "Premium AI-powered note organization with smart summaries and offline flashcards.",
    "start_url": "/",
    "scope": "/",
    "lang": "en",
    "dir": "ltr",
    "display": "standalone",
    "display_override": [
        "tabbed",
        "window-controls-overlay",
        "standalone",
        "minimal-ui"
    ],
    "tab_strip": {
        "home_tab": "auto",
        "new_tab_button": {
            "url": "/"
        }
    },
    "orientation": "any",
    "background_color": "#09090b",
    "theme_color": "#4f46e5",
    "categories": [
        "productivity",
        "education",
        "business",
        "utilities"
    ],
    "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
    "prefer_related_applications": false,
    "related_applications": [
        {
            "platform": "play",
            "url": "https://play.google.com/store/apps/details?id=com.ainotes.organizer",
            "id": "com.ainotes.organizer"
        },
        {
            "platform": "windows",
            "url": "https://www.microsoft.com/store/apps/9WZDNCRFJ364",
            "id": "9WZDNCRFJ364"
        }
    ],
    "icons": [
        {
            "src": "/icon-192x192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "/icon-512x512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "/icon-512x512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "maskable"
        }
    ],
    "screenshots": [
        {
            "src": "/screenshot_1.png",
            "sizes": "1424x884",
            "type": "image/png",
